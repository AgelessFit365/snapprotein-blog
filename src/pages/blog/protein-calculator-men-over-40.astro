  <script>
    function calculateProtein() {
      var input = document.getElementById('weight-input');
      var output = document.getElementById('calc-output');
      var weight = parseFloat(input.value);

      if (!weight || weight < 80 || weight > 450) {
        input.style.borderColor = '#ef4444';
        setTimeout(function() { input.style.borderColor = 'rgba(255,255,255,0.2)'; }, 1500);
        return;
      }

      // 1.2g/kg — convert lbs to kg first (divide by 2.205)
      var kg = weight / 2.205;
      var daily = Math.round(kg * 1.2);
      var perMeal = Math.round(daily / 4);
      var perMealHigh = perMeal + 2;

      // Output elements
      document.getElementById('output-daily-num').textContent = daily;
      document.getElementById('output-meals').textContent =
        'That\'s roughly 4 meals × ' + perMeal + '–' + perMealHigh + 'g each';

      // Contextual insight
      var insight = '';
      if (daily < 100) {
        insight = 'Most men your size are hitting 50–65g without realizing it — nearly half what you actually need. That gap is where muscle loss quietly happens, year after year.';
      } else if (daily <= 130) {
        insight = 'This is the sweet spot for men over 40 focused on muscle preservation. Most men your size are 30–50g short of this without knowing it. Now you have the number — the next step is seeing it every day.';
      } else {
        insight = 'At your size, hitting this consistently is the job. Spreading it across 4–5 meals makes it doable without any single meal feeling like a challenge. Consistency over perfection.';
      }
      document.getElementById('output-insight').textContent = insight;

      output.classList.add('visible');
    }

    // Allow Enter key to trigger calculation
    document.getElementById('weight-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') calculateProtein();
    });
  </script>

