        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Whey protein</td>
          <td><span class="speed-fast">Fast</span></td>
          <td>60–90 min</td>
          <td>Post-workout, morning</td>
        </tr>
        <tr>
          <td>Eggs</td>
          <td><span class="speed-med">Medium</span></td>
          <td>2–3 hours</td>
          <td>Any meal, versatile</td>
        </tr>
        <tr>
          <td>Chicken / fish</td>
