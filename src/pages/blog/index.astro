<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>SnapProtein Blog</title>
    <meta
      name="description"
      content="Evidence-based articles on protein, muscle, and healthy aging."
    />
    <style>
      :root {
        --charcoal: #1e2124;
        --green: #3a6b45;
        --green-light: #4d8c5a;
        --cream: #f9f6f0;
        --text: #1e2124;
        --text-muted: #5a6370;
        --border: #d8dde3;
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: var(--cream);
        color: var(--text);
      }

      .site-header {
        background: var(--charcoal);
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .site-header a.logo {
        color: white;
        text-decoration: none;
        font-weight: 800;
        font-size: 1.2rem;
      }

      .site-header a.logo span {
        color: var(--green-light);
      }

      .site-header nav a {
        color: rgba(255,255,255,0.75);
        text-decoration: none;
        margin-left: 1.25rem;
        font-size: 0.9rem;
      }

      .site-header nav a:hover {
        color: white;
      }

      .hero {
        background: var(--charcoal);
        color: white;
        text-align: center;
        padding: 3.5rem 1.5rem 3rem;
      }

      .hero h1 {
        margin: 0 0 0.75rem;
        font-size: 2.5rem;
      }

      .hero p {
        margin: 0 auto;
        max-width: 680px;
        color: rgba(255,255,255,0.72);
        line-height: 1.6;
      }

      .wrap {
        max-width: 820px;
        margin: 0 auto;
        padding: 3rem 1.5rem 4rem;
      }

      .post-list {
        display: grid;
        gap: 1.25rem;
      }

      .post-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.5rem;
      }

      .post-card h2 {
        margin: 0 0 0.6rem;
        font-size: 1.4rem;
        line-height: 1.25;
      }

      .post-card h2 a {
        color: var(--text);
        text-decoration: none;
      }

      .post-card h2 a:hover {
        color: var(--green);
      }

      .post-card p {
        margin: 0;
        color: var(--text-muted);
        line-height: 1.6;
      }

      footer {
        background: var(--charcoal);
        color: rgba(255,255,255,0.45);
        text-align: center;
        padding: 2rem 1rem;
        font-size: 0.8rem;
      }
    </style>
  </head>
  <body>
