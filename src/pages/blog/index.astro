---
import { posts } from '../../data/posts.js';
const sorted = [...posts].sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
const featured = posts.find(p => p.url.includes('what-120g-protein-look-like'));
const rest = sorted.filter(p => !p.url.includes('what-120g-protein-look-like'));
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SnapProtein Blog – Protein, Muscle & Healthy Aging After 40</title>
  <meta name="description" content="Evidence-based articles on protein, muscle loss, and healthy aging for men over 40. No fluff — just what actually works." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Google tag -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FX274TDD3B"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-FX274TDD3B');
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --charcoal:    #1e2124;
      --charcoal-2:  #252a2d;
      --green:       #3a6b45;
      --green-light: #4d8c5a;
      --green-pale:  #e8f2ea;
      --cta-band:    #1e3d2f;
      --cream:       #f9f6f0;
      --white:       #ffffff;
      --text:        #1e2124;
      --muted:       #5a6370;
      --border:      #e2e8f0;
    }

    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--cream);
      color: var(--text);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    .site-header {
      background: var(--charcoal);
      padding: 14px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .logo {
      color: #fff;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1.15rem;
      letter-spacing: -0.02em;
    }
    .logo span { color: var(--green-light); }
    .site-header nav { display: flex; gap: 20px; flex-wrap: wrap; }
    .site-header nav a {
      color: #9aab9e;
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      transition: color 0.2s;
    }
    .site-header nav a:hover { color: #fff; }

    /* ── HERO ── */
    .blog-hero {
      background: var(--charcoal);
      padding: 56px 24px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .blog-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(77,140,90,0.1) 0%, transparent 70%);
      pointer-events: none;
    }
    .blog-hero-label {
      display: inline-block;
      background: rgba(77,140,90,0.15);
      border: 1px solid rgba(77,140,90,0.3);
      color: #7ec48c;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 100px;
      margin-bottom: 18px;
    }
    .blog-hero h1 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: 14px;
    }
    .blog-hero h1 em {
      font-style: normal;
      color: var(--green-light);
    }
    .blog-hero p {
      color: #8fa89a;
      font-size: 1rem;
      max-width: 540px;
      margin: 0 auto;
      line-height: 1.75;
    }

    /* ── MAIN WRAP ── */
    .wrap {
      max-width: 1120px;
      margin: 0 auto;
      padding: 48px 24px 72px;
    }

    /* ── FEATURED POST ── */
    .featured-label {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 14px;
    }
    .featured-card {
      background: var(--charcoal);
      border-radius: 12px;
      padding: 40px 44px;
      margin-bottom: 52px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: center;
      position: relative;
      overflow: hidden;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 24px rgba(0,0,0,0.15);
    }
    .featured-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 4px;
      height: 100%;
      background: var(--green-light);
      border-radius: 12px 0 0 12px;
    }
    .featured-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.25);
    }
    .featured-tag {
      display: inline-block;
      background: rgba(77,140,90,0.2);
      border: 1px solid rgba(77,140,90,0.35);
      color: #7ec48c;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 100px;
      margin-bottom: 14px;
    }
    .featured-card h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.2rem, 2.5vw, 1.7rem);
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.02em;
      line-height: 1.25;
      margin-bottom: 12px;
    }
    .featured-card p {
      color: #8fa89a;
      font-size: 0.97rem;
      line-height: 1.7;
      margin-bottom: 20px;
    }
    .featured-meta {
      font-size: 0.78rem;
      color: #4d6054;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 600;
    }
    .featured-arrow {
      font-size: 2rem;
      color: var(--green-light);
      opacity: 0.5;
      flex-shrink: 0;
      transition: opacity 0.2s, transform 0.2s;
    }
    .featured-card:hover .featured-arrow {
      opacity: 1;
      transform: translateX(4px);
    }

    /* ── SECTION DIVIDER ── */
    .section-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
    }
    .section-divider span {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      white-space: nowrap;
    }
    .section-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── POST GRID ── */
    .post-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }
    @media (max-width: 900px) { .post-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 580px) { .post-grid { grid-template-columns: 1fr; } }

    /* ── POST CARD ── */
    .post-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 24px 22px 20px;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      transition: transform 0.18s, box-shadow 0.18s;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
      border-top: 3px solid transparent;
    }
    .post-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 28px rgba(58,107,69,0.12);
      border-top-color: var(--green-light);
    }
    .post-card-date {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #aab4be;
      margin-bottom: 10px;
    }
    .post-card h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.35;
      margin-bottom: 10px;
      letter-spacing: -0.01em;
      flex: 1;
    }
    .post-card p {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 16px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .post-card-read {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--green);
      display: flex;
      align-items: center;
      gap: 4px;
      margin-top: auto;
    }
    .post-card:hover .post-card-read { color: var(--green-light); }

    /* ── CTA BAND ── */
    .cta-band {
      background: var(--cta-band);
      padding: 64px 24px;
      text-align: center;
    }
    .cta-band h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: clamp(1.4rem, 3vw, 2rem);
      color: #fff;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
      line-height: 1.2;
    }
    .cta-band p {
      color: #7aab87;
      font-size: 1rem;
      max-width: 480px;
      margin: 0 auto 28px;
      line-height: 1.7;
    }
    .cta-btn {
      display: inline-block;
      background: #fff;
      color: var(--cta-band);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 0.97rem;
      padding: 14px 30px;
      border-radius: 8px;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .cta-btn:hover { opacity: 0.9; }

    /* ── BOTTOM NAV ── */
    .bottom-nav {
      background: var(--charcoal);
      padding: 16px 24px;
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .bottom-nav a {
      color: #94a3b8;
      text-decoration: none;
      font-size: 0.85rem;
      transition: color 0.2s;
    }
    .bottom-nav a:hover { color: #fff; }

    /* ── FOOTER ── */
    footer {
      background: #111;
      color: #4a5568;
      text-align: center;
      padding: 20px 24px;
      font-size: 0.8rem;
    }
    footer a { color: #4a5568; text-decoration: underline; }

    @media (max-width: 640px) {
      .featured-card {
        grid-template-columns: 1fr;
        padding: 28px 24px;
      }
      .featured-arrow { display: none; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <header class="site-header">
    <a href="https://snapprotein.com" class="logo">Snap<span>Protein</span></a>
    <nav>
      <a href="https://snapprotein.com">Home</a>
      <a href="/blog/">Blog</a>
      <a href="/blog/protein-per-day-after-40/">How Much Protein</a>
      <a href="/blog/best-protein-tracking-app/">Best Tracker</a>
      <a href="https://snapprotein.com">Start Tracking</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="blog-hero">
    <div class="blog-hero-label">SnapProtein Blog</div>
    <h1>Protein, Muscle &amp; <em>Healthy Aging</em><br>After 40</h1>
    <p>No fluff. Evidence-based articles on the one number that matters most for men over 40.</p>
  </section>

  <!-- MAIN -->
  <main class="wrap">

    <!-- FEATURED -->
    <div class="featured-label">Most Read</div>
    <a href={featured.url} class="featured-card">
      <div>
        <div class="featured-tag">Featured</div>
        <h2>{featured.title}</h2>
        <p>{featured.description}</p>
        <div class="featured-meta">{new Date(featured.pubDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</div>
      </div>
      <div class="featured-arrow">→</div>
    </a>

    <!-- GRID -->
    <div class="section-divider">
      <span>All Articles — {rest.length} posts</span>
    </div>

    <div class="post-grid">
      {rest.map(post => (
        <a href={post.url} class="post-card">
          <div class="post-card-date">
            {new Date(post.pubDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
          </div>
          <h2>{post.title}</h2>
          <p>{post.description}</p>
          <div class="post-card-read">Read article →</div>
        </a>
      ))}
    </div>

  </main>

  <!-- CTA -->
  <section class="cta-band">
    <h2>Ready to see your number?</h2>
    <p>The simple protein tracker built for men who are done with apps that feel like homework.</p>
    <a href="https://snapprotein.com" class="cta-btn">Try SnapProtein Free →</a>
  </section>

  <!-- BOTTOM NAV -->
  <nav class="bottom-nav">
    <a href="https://snapprotein.com">Home</a>
    <a href="/blog/">Blog</a>
    <a href="/blog/protein-per-day-after-40/">How Much Protein</a>
    <a href="/blog/best-protein-tracking-app/">Best Tracker</a>
    <a href="https://snapprotein.com">Start Tracking</a>
  </nav>

  <footer>
    <p>© 2026 SnapProtein · <a href="https://snapprotein.com/privacy/">Privacy Policy</a></p>
  </footer>

</body>
</html>